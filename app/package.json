{
  "name": "combo-hifi",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "electron:preview": "npm run build && electron .",
    "electron:package": "npm run build && electron-packager . Combo --platform=win32 --arch=x64 --out=release --overwrite --ignore=node_modules --ignore=src --ignore=release --ignore=.env",
    "electron:build": "npm run build && electron-builder",
    "electron:publish": "npm run build && node scripts/publish.cjs"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "build": {
    "appId": "com.combo.game",
    "productName": "Combo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "Valaraukar56",
      "repo": "combo",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
